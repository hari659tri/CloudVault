<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CloudVault — Your Drive</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0d0f14; --panel: #13161e; --panel-border: #1e2330; --sidebar: #10121a;
      --accent: #6c63ff; --accent-glow: rgba(108,99,255,0.3); --accent-soft: rgba(108,99,255,0.1);
      --text-primary: #eef0f6; --text-secondary: #7b82a0; --text-muted: #3d4460;
      --success: #34d399; --warning: #fbbf24; --error: #f87171;
      --card: #161922; --card-hover: #1c1f2e;
    }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text-primary); min-height: 100vh; display: flex; overflow: hidden; }

    /* ── SIDEBAR ── */
    .sidebar { width: 220px; min-width: 220px; background: var(--sidebar); border-right: 1px solid var(--panel-border); display: flex; flex-direction: column; padding: 20px 0; z-index: 10; }
    .logo { display: flex; align-items: center; gap: 10px; padding: 0 20px 24px; border-bottom: 1px solid var(--panel-border); }
    .logo-icon { width: 32px; height: 32px; background: var(--accent); border-radius: 10px; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 16px var(--accent-glow); }
    .logo-text { font-family: 'Sora', sans-serif; font-size: 15px; font-weight: 700; color: var(--text-primary); }
    .logo-text span { color: var(--accent); }
    .nav { padding: 16px 12px; flex: 1; }
    .nav-label { font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); padding: 0 8px; margin-bottom: 6px; margin-top: 16px; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 10px; border-radius: 10px; color: var(--text-secondary); font-size: 13.5px; cursor: pointer; transition: background 0.2s, color 0.2s; text-decoration: none; margin-bottom: 2px; }
    .nav-item:hover { background: var(--accent-soft); color: var(--text-primary); }
    .nav-item.active { background: var(--accent-soft); color: var(--accent); font-weight: 500; border: 1px solid rgba(108,99,255,0.2); }
    .nav-item svg { width: 16px; height: 16px; flex-shrink: 0; }
    .storage { padding: 16px 20px; border-top: 1px solid var(--panel-border); }
    .storage-label { font-size: 11px; color: var(--text-secondary); margin-bottom: 8px; display: flex; justify-content: space-between; }
    .storage-bar { height: 4px; background: var(--panel-border); border-radius: 4px; overflow: hidden; }
    .storage-fill { height: 100%; width: 0%; background: linear-gradient(90deg, var(--accent), #a89fff); border-radius: 4px; transition: width 0.8s ease; }
    .storage-text { font-size: 11px; color: var(--text-muted); margin-top: 6px; }
    .user-bar { padding: 14px 20px; border-top: 1px solid var(--panel-border); display: flex; align-items: center; gap: 10px; }
    .avatar { width: 32px; height: 32px; background: linear-gradient(135deg, var(--accent), #a89fff); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Sora', sans-serif; font-size: 13px; font-weight: 700; color: #fff; flex-shrink: 0; }
    .user-info { flex: 1; min-width: 0; }
    .user-name { font-size: 13px; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-email { font-size: 11px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .logout-btn { font-size: 11px; color: var(--error); background: none; border: none; cursor: pointer; padding: 4px 8px; border-radius: 6px; transition: background 0.2s; white-space: nowrap; }
    .logout-btn:hover { background: rgba(248,113,113,0.1); }

    /* ── MAIN ── */
    .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    .topbar { height: 60px; border-bottom: 1px solid var(--panel-border); display: flex; align-items: center; padding: 0 24px; gap: 16px; background: var(--sidebar); }
    .search-wrap { flex: 1; max-width: 400px; position: relative; }
    .search-wrap svg { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted); width: 15px; height: 15px; }
    .search-input { width: 100%; background: var(--panel); border: 1px solid var(--panel-border); border-radius: 10px; color: var(--text-primary); font-family: 'DM Sans', sans-serif; font-size: 13.5px; padding: 8px 14px 8px 36px; outline: none; transition: border-color 0.2s, box-shadow 0.2s; }
    .search-input::placeholder { color: var(--text-muted); }
    .search-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
    .topbar-actions { display: flex; align-items: center; gap: 10px; margin-left: auto; }
    .icon-btn { width: 34px; height: 34px; background: var(--panel); border: 1px solid var(--panel-border); border-radius: 9px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--text-secondary); transition: background 0.2s, color 0.2s; border: none; }
    .icon-btn:hover { background: var(--card-hover); color: var(--text-primary); }
    .icon-btn svg { width: 15px; height: 15px; }
    .upload-btn { display: flex; align-items: center; gap: 8px; background: var(--accent); border: none; border-radius: 10px; color: #fff; font-family: 'Sora', sans-serif; font-size: 13px; font-weight: 600; padding: 8px 16px; cursor: pointer; transition: transform 0.15s, box-shadow 0.2s; box-shadow: 0 4px 16px var(--accent-glow); }
    .upload-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 24px var(--accent-glow); }
    .upload-btn svg { width: 15px; height: 15px; }

    /* ── CONTENT ── */
    .content { flex: 1; overflow-y: auto; padding: 24px; }
    .content::-webkit-scrollbar { width: 4px; }
    .content::-webkit-scrollbar-thumb { background: var(--panel-border); border-radius: 4px; }
    .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .section-title { font-family: 'Sora', sans-serif; font-size: 15px; font-weight: 600; color: var(--text-primary); }

    /* Stats */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 28px; }
    .stat-card { background: var(--card); border: 1px solid var(--panel-border); border-radius: 14px; padding: 16px; display: flex; align-items: center; gap: 14px; transition: background 0.2s; animation: fadeUp 0.5s ease both; }
    .stat-card:hover { background: var(--card-hover); }
    .stat-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .stat-icon svg { width: 20px; height: 20px; }
    .stat-val { font-family: 'Sora', sans-serif; font-size: 18px; font-weight: 700; color: var(--text-primary); }
    .stat-lbl { font-size: 11.5px; color: var(--text-secondary); margin-top: 2px; }

    /* File Grid */
    .files-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 14px; margin-bottom: 28px; min-height: 80px; }
    .file-card {
      background: var(--card); border: 1px solid var(--panel-border); border-radius: 14px;
      padding: 16px 14px; cursor: pointer; transition: background 0.2s, border-color 0.2s, transform 0.15s;
      animation: fadeUp 0.5s ease both; position: relative; overflow: hidden;
    }
    .file-card:hover { background: var(--card-hover); border-color: rgba(108,99,255,0.25); transform: translateY(-2px); }
    .file-icon { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }
    .file-icon svg { width: 22px; height: 22px; }
    .file-name { font-size: 13px; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 4px; }
    .file-meta { font-size: 11px; color: var(--text-muted); }

    /* Open hint */
    .file-open-hint {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: linear-gradient(to top, rgba(108,99,255,0.2), transparent);
      color: var(--accent); font-size: 10px; font-weight: 600; letter-spacing: 0.05em;
      text-align: center; padding: 8px 4px 6px; opacity: 0; transition: opacity 0.2s;
      text-transform: uppercase;
    }
    .file-card:hover .file-open-hint { opacity: 1; }

    /* Delete btn on card */
    .file-del {
      position: absolute; top: 8px; right: 8px; width: 26px; height: 26px;
      background: rgba(248,113,113,0.12); border: 1px solid rgba(248,113,113,0.2);
      border-radius: 7px; color: var(--error); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity 0.2s, background 0.2s;
    }
    .file-card:hover .file-del { opacity: 1; }
    .file-del:hover { background: rgba(248,113,113,0.3); }

    /* Recent Table */
    .recent-table { background: var(--card); border: 1px solid var(--panel-border); border-radius: 14px; overflow: hidden; }
    .table-head { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 100px; padding: 10px 16px; border-bottom: 1px solid var(--panel-border); background: var(--sidebar); }
    .table-head span { font-size: 11px; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-muted); }
    .table-row {
      display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 100px;
      padding: 11px 16px; border-bottom: 1px solid var(--panel-border);
      align-items: center; transition: background 0.15s;
      cursor: pointer; animation: fadeUp 0.4s ease both;
    }
    .table-row:last-child { border-bottom: none; }
    .table-row:hover { background: var(--card-hover); }
    .row-name { display: flex; align-items: center; gap: 10px; }
    .row-icon { width: 28px; height: 28px; border-radius: 7px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .row-icon svg { width: 14px; height: 14px; }
    .row-filename { font-size: 13px; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .row-cell { font-size: 12px; color: var(--text-secondary); }
    .row-badge { font-size: 10px; padding: 3px 8px; border-radius: 100px; font-weight: 500; display: inline-block; }
    .del-row-btn { background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.2); border-radius: 7px; color: var(--error); font-size: 11px; font-weight: 500; padding: 5px 10px; cursor: pointer; transition: background 0.2s; white-space: nowrap; }
    .del-row-btn:hover { background: rgba(248,113,113,0.25); }

    .empty-state { text-align: center; padding: 40px 20px; color: var(--text-muted); font-size: 13px; }
    .empty-state svg { width: 40px; height: 40px; margin: 0 auto 10px; display: block; opacity: 0.3; }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

    /* ── MODAL ── */
    .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(6px); z-index: 100; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.25s; }
    .modal-overlay.open { opacity: 1; pointer-events: all; }
    .modal { background: var(--panel); border: 1px solid var(--panel-border); border-radius: 20px; padding: 28px; width: 100%; max-width: 460px; position: relative; box-shadow: 0 40px 80px rgba(0,0,0,0.6); transform: translateY(20px) scale(0.97); transition: transform 0.25s cubic-bezier(0.22,1,0.36,1); }
    .modal-overlay.open .modal { transform: translateY(0) scale(1); }
    .modal-close { position: absolute; top: 16px; right: 16px; width: 30px; height: 30px; background: var(--panel-border); border: none; border-radius: 8px; color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s, color 0.2s; }
    .modal-close:hover { background: var(--error); color: #fff; }
    .modal-close svg { width: 14px; height: 14px; }
    .modal-title { font-family: 'Sora', sans-serif; font-size: 17px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px; }
    .modal-sub { font-size: 13px; color: var(--text-secondary); margin-bottom: 20px; }
    .dropzone { border: 2px dashed var(--panel-border); border-radius: 14px; padding: 36px 20px; text-align: center; cursor: pointer; transition: border-color 0.2s, background 0.2s; position: relative; }
    .dropzone:hover, .dropzone.drag-over { border-color: var(--accent); background: var(--accent-soft); }
    .dropzone input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
    .dropzone-icon { width: 52px; height: 52px; background: var(--accent-soft); border: 1px solid rgba(108,99,255,0.2); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; }
    .dropzone-icon svg { width: 26px; height: 26px; color: var(--accent); }
    .dropzone-title { font-family: 'Sora', sans-serif; font-size: 14px; font-weight: 600; color: var(--text-primary); margin-bottom: 6px; }
    .dropzone-sub { font-size: 12px; color: var(--text-secondary); line-height: 1.5; }
    .dropzone-sub span { color: var(--accent); font-weight: 500; }
    .file-types { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
    .file-type-tag { font-size: 11px; padding: 4px 10px; border-radius: 100px; background: var(--panel-border); color: var(--text-secondary); font-weight: 500; }
    .upload-progress { display: none; margin-top: 16px; }
    .upload-progress.show { display: block; }
    .progress-file { display: flex; align-items: center; gap: 12px; padding: 10px 12px; background: var(--card); border: 1px solid var(--panel-border); border-radius: 10px; margin-bottom: 8px; }
    .progress-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .progress-info { flex: 1; min-width: 0; }
    .progress-name { font-size: 12.5px; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .progress-bar-wrap { height: 3px; background: var(--panel-border); border-radius: 4px; margin-top: 6px; overflow: hidden; }
    .progress-bar { height: 100%; background: var(--accent); border-radius: 4px; width: 0%; transition: width 0.3s; }
    .progress-pct { font-size: 11px; color: var(--text-muted); white-space: nowrap; }
    .modal-footer { display: flex; gap: 10px; margin-top: 20px; }
    .btn-cancel { flex: 1; background: var(--panel-border); border: none; border-radius: 10px; color: var(--text-secondary); font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500; padding: 10px; cursor: pointer; transition: background 0.2s; }
    .btn-cancel:hover { background: var(--card-hover); color: var(--text-primary); }
    .btn-upload { flex: 2; background: var(--accent); border: none; border-radius: 10px; color: #fff; font-family: 'Sora', sans-serif; font-size: 13px; font-weight: 600; padding: 10px; cursor: pointer; box-shadow: 0 4px 16px var(--accent-glow); transition: transform 0.15s; }
    .btn-upload:hover { transform: translateY(-1px); }
    .btn-upload:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

    @media (max-width: 768px) {
      .sidebar { display: none; }
      .stats-grid { grid-template-columns: repeat(2,1fr); }
      .files-grid { grid-template-columns: repeat(auto-fill, minmax(130px,1fr)); }
      .table-head, .table-row { grid-template-columns: 2fr 1fr 100px; }
    }
  </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="logo">
    <div class="logo-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><path d="M3 15a4 4 0 0 0 4 4h10a4 4 0 0 0 4-4V9a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v6z"/><path d="M8 12l3 3 5-5"/></svg>
    </div>
    <span class="logo-text">Cloud<span>Vault</span></span>
  </div>

  <nav class="nav">
    <div class="nav-label">Main</div>
    <a class="nav-item active" href="/home">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </a>
    <a class="nav-item" href="#">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
      My Files
    </a>
    <a class="nav-item" href="#">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      Starred
    </a>
    <div class="nav-label">Filter</div>
    <a class="nav-item" href="#">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/></svg>
      Images
    </a>
    <a class="nav-item" href="#">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      Documents
    </a>
    <a class="nav-item" href="#">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
      Trash
    </a>
  </nav>

  <div class="storage">
    <div class="storage-label"><span>Storage</span><span style="color:var(--accent)" id="storePct">0%</span></div>
    <div class="storage-bar"><div class="storage-fill" id="storeFill"></div></div>
    <div class="storage-text" id="storeText">Calculating...</div>
  </div>

  <div class="user-bar">
    <div class="avatar" id="avatarLetter">?</div>
    <div class="user-info">
      <div class="user-name" id="userName">Loading...</div>
      <div class="user-email" id="userEmail"></div>
    </div>
    <a href="/user/logout"><button class="logout-btn">Logout</button></a>
  </div>
</aside>

<!-- MAIN -->
<main class="main">
  <div class="topbar">
    <div class="search-wrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input class="search-input" id="searchInput" type="text" placeholder="Search files..." />
    </div>
    <div class="topbar-actions">
      <button class="icon-btn" title="Refresh" onclick="loadFiles()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
      </button>
      <button class="upload-btn" id="openUpload">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 5 5 12"/></svg>
        Upload File
      </button>
    </div>
  </div>

  <div class="content">
    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card" style="animation-delay:0.05s">
        <div class="stat-icon" style="background:rgba(108,99,255,0.12)">
          <svg viewBox="0 0 24 24" fill="none" stroke="#6c63ff" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div><div class="stat-val" id="totalFiles">0</div><div class="stat-lbl">Total Files</div></div>
      </div>
      <div class="stat-card" style="animation-delay:0.1s">
        <div class="stat-icon" style="background:rgba(52,211,153,0.12)">
          <svg viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/></svg>
        </div>
        <div><div class="stat-val" id="totalImages">0</div><div class="stat-lbl">Images</div></div>
      </div>
      <div class="stat-card" style="animation-delay:0.15s">
        <div class="stat-icon" style="background:rgba(251,191,36,0.12)">
          <svg viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        </div>
        <div><div class="stat-val" id="totalVideos">0</div><div class="stat-lbl">Videos</div></div>
      </div>
      <div class="stat-card" style="animation-delay:0.2s">
        <div class="stat-icon" style="background:rgba(248,113,113,0.12)">
          <svg viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div><div class="stat-val" id="totalStorage">0 MB</div><div class="stat-lbl">Used Storage</div></div>
      </div>
    </div>

    <!-- Quick Access -->
    <div class="section-header">
      <div class="section-title">Quick Access</div>
    </div>
    <div class="files-grid" id="filesGrid">
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
        <p>No files yet — upload your first file!</p>
      </div>
    </div>

    <!-- Recent Files -->
    <div class="section-header">
      <div class="section-title">Recent Files</div>
    </div>
    <div class="recent-table">
      <div class="table-head">
        <span>Name</span><span>Size</span><span>Type</span><span>Uploaded</span><span>Action</span>
      </div>
      <div id="recentTableBody">
        <div class="empty-state"><p>No files uploaded yet.</p></div>
      </div>
    </div>
  </div>
</main>

<!-- UPLOAD MODAL -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <button class="modal-close" id="closeModal">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="modal-title">Upload Files</div>
    <div class="modal-sub">Drag & drop or click to browse your files</div>
    <div class="dropzone" id="dropzone">
      <input type="file" id="fileInput" multiple accept="*/*" />
      <div class="dropzone-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
      </div>
      <div class="dropzone-title">Drop your files here</div>
      <div class="dropzone-sub">or <span>click to browse</span> from your computer<br/>Max file size: 100MB</div>
    </div>
    <div class="file-types">
      <span class="file-type-tag">PNG</span><span class="file-type-tag">JPG</span>
      <span class="file-type-tag">PDF</span><span class="file-type-tag">MP4</span>
      <span class="file-type-tag">DOCX</span><span class="file-type-tag">+ more</span>
    </div>
    <div class="upload-progress" id="uploadProgress"></div>
    <div class="modal-footer">
      <button class="btn-cancel" id="cancelBtn">Cancel</button>
      <button class="btn-upload" id="uploadBtn">Upload Files</button>
    </div>
  </div>
</div>

<script>
const BASE = '';
let allFiles = [];

// ══════════════════════════════════════
// GET USER INFO FROM JWT COOKIE
// ══════════════════════════════════════
function getUserFromCookie() {
  try {
    const token = document.cookie.split(';').map(c => c.trim()).find(c => c.startsWith('token='));
    if (!token) return null;
    const payload = JSON.parse(atob(token.split('=')[1].split('.')[1]));
    return payload;
  } catch(e) { return null; }
}

const user = getUserFromCookie();
if (user) {
  document.getElementById('userName').textContent  = (user.firstName || '') + ' ' + (user.lastName || '');
  document.getElementById('userEmail').textContent = user.email || '';
  document.getElementById('avatarLetter').textContent = (user.firstName || '?')[0].toUpperCase();
}

// ══════════════════════════════════════
// HELPERS
// ══════════════════════════════════════
function formatSize(bytes) {
  if (!bytes) return '0 B';
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024*1024) return (bytes/1024).toFixed(1) + ' KB';
  return (bytes/(1024*1024)).toFixed(1) + ' MB';
}

function timeAgo(d) {
  const diff = Date.now() - new Date(d).getTime();
  const m = Math.floor(diff/60000), h = Math.floor(diff/3600000), days = Math.floor(diff/86400000);
  if (m < 1)  return 'Just now';
  if (m < 60) return m + 'm ago';
  if (h < 24) return h + 'h ago';
  return days + 'd ago';
}

function getColor(type) {
  if (!type) return '#7b82a0';
  if (type.includes('image')) return '#34d399';
  if (type.includes('video')) return '#fbbf24';
  if (type.includes('pdf'))   return '#f87171';
  return '#6c63ff';
}

function getIcon(type) {
  if (type && type.includes('image')) return `<rect x="2" y="3" width="20" height="14" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>`;
  if (type && type.includes('video')) return `<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>`;
  return `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>`;
}

// ══════════════════════════════════════
// ✅ OPEN FILE IN NEW TAB
// ══════════════════════════════════════
function openFile(url, event) {
  // Don't open if delete button was clicked
  if (event && event.target.closest('.file-del, .del-row-btn')) return;
  window.open(url, '_blank');
}

// ══════════════════════════════════════
// LOAD FILES
// ══════════════════════════════════════
async function loadFiles() {
  try {
    const res  = await fetch(`${BASE}/file/files`);
    const data = await res.json();
    allFiles   = data.files || [];
    renderFiles(allFiles);
    updateStats(allFiles);
  } catch(e) {
    console.error('Load error:', e);
  }
}

// ══════════════════════════════════════
// RENDER FILES
// ══════════════════════════════════════
function renderFiles(files) {
  const grid  = document.getElementById('filesGrid');
  const table = document.getElementById('recentTableBody');

  if (!files.length) {
    grid.innerHTML  = `<div class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg><p>No files yet — upload your first file!</p></div>`;
    table.innerHTML = `<div class="empty-state"><p>No files uploaded yet.</p></div>`;
    return;
  }

  // ✅ File cards — click to OPEN, delete btn to DELETE
  grid.innerHTML = files.map(f => `
    <div class="file-card" id="card-${f._id}" onclick="openFile('${f.fileUrl}', event)" title="Click to open">
      <button class="file-del" onclick="deleteFile('${f._id}', event)" title="Delete file">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/>
        </svg>
      </button>
      <div class="file-icon" style="background:${getColor(f.fileType)}22">
        <svg viewBox="0 0 24 24" fill="none" stroke="${getColor(f.fileType)}" stroke-width="2">${getIcon(f.fileType)}</svg>
      </div>
      <div class="file-name" title="${f.fileName}">${f.fileName}</div>
      <div class="file-meta">${formatSize(f.fileSize)} · ${timeAgo(f.createdAt)}</div>
      <div class="file-open-hint">↗ Open file</div>
    </div>`).join('');

  // ✅ Table rows — click row to OPEN, delete btn to DELETE
  table.innerHTML = files.map(f => `
    <div class="table-row" id="row-${f._id}" onclick="openFile('${f.fileUrl}', event)" title="Click to open">
      <div class="row-name">
        <div class="row-icon" style="background:${getColor(f.fileType)}22">
          <svg viewBox="0 0 24 24" fill="none" stroke="${getColor(f.fileType)}" stroke-width="2">${getIcon(f.fileType)}</svg>
        </div>
        <span class="row-filename" title="${f.fileName}">${f.fileName}</span>
      </div>
      <span class="row-cell">${formatSize(f.fileSize)}</span>
      <span class="row-cell">
        <span class="row-badge" style="background:${getColor(f.fileType)}22;color:${getColor(f.fileType)}">
          ${(f.fileName.split('.').pop() || 'FILE').toUpperCase()}
        </span>
      </span>
      <span class="row-cell">${timeAgo(f.createdAt)}</span>
      <span class="row-cell">
        <button class="del-row-btn" onclick="deleteFile('${f._id}', event)">🗑 Delete</button>
      </span>
    </div>`).join('');
}

// ══════════════════════════════════════
// UPDATE STATS
// ══════════════════════════════════════
function updateStats(files) {
  const images     = files.filter(f => f.fileType && f.fileType.includes('image')).length;
  const videos     = files.filter(f => f.fileType && f.fileType.includes('video')).length;
  const totalBytes = files.reduce((s, f) => s + (f.fileSize || 0), 0);
  document.getElementById('totalFiles').textContent   = files.length;
  document.getElementById('totalImages').textContent  = images;
  document.getElementById('totalVideos').textContent  = videos;
  document.getElementById('totalStorage').textContent = formatSize(totalBytes);
  const pct = Math.min(100, Math.round(totalBytes / (15 * 1024 * 1024 * 1024) * 100));
  document.getElementById('storePct').textContent  = pct + '%';
  document.getElementById('storeFill').style.width = pct + '%';
  document.getElementById('storeText').textContent = formatSize(totalBytes) + ' of 15 GB used';
}

// ══════════════════════════════════════
// DELETE FILE
// ══════════════════════════════════════
async function deleteFile(id, event) {
  event.stopPropagation(); // ✅ prevent opening file when deleting
  if (!confirm('Delete this file permanently?')) return;
  try {
    const res  = await fetch(`${BASE}/file/delete/${id}`, { method: 'DELETE' });
    const data = await res.json();
    if (res.ok) {
      document.getElementById('card-' + id)?.remove();
      document.getElementById('row-'  + id)?.remove();
      allFiles = allFiles.filter(f => f._id !== id);
      updateStats(allFiles);
      if (!allFiles.length) renderFiles([]);
    } else {
      alert('Delete failed: ' + data.message);
    }
  } catch(e) {
    console.error('Delete error:', e);
  }
}

// ══════════════════════════════════════
// SEARCH
// ══════════════════════════════════════
document.getElementById('searchInput').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  renderFiles(allFiles.filter(f => f.fileName.toLowerCase().includes(q)));
});

// ══════════════════════════════════════
// MODAL
// ══════════════════════════════════════
const overlay   = document.getElementById('modalOverlay');
const fileInput = document.getElementById('fileInput');
const uploadBtn = document.getElementById('uploadBtn');
const progress  = document.getElementById('uploadProgress');
const dropzone  = document.getElementById('dropzone');

document.getElementById('openUpload').addEventListener('click', () => overlay.classList.add('open'));

const closeModal = () => {
  overlay.classList.remove('open');
  progress.innerHTML = '';
  progress.classList.remove('show');
  fileInput.value = '';
  uploadBtn.textContent = 'Upload Files';
  uploadBtn.style.background = '';
  uploadBtn.disabled = false;
};
document.getElementById('closeModal').addEventListener('click', closeModal);
document.getElementById('cancelBtn').addEventListener('click', closeModal);
overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

dropzone.addEventListener('dragover',  e => { e.preventDefault(); dropzone.classList.add('drag-over'); });
dropzone.addEventListener('dragleave', () => dropzone.classList.remove('drag-over'));
dropzone.addEventListener('drop', e => {
  e.preventDefault();
  dropzone.classList.remove('drag-over');
  showProgressBars(e.dataTransfer.files);
});
fileInput.addEventListener('change', () => showProgressBars(fileInput.files));

function showProgressBars(files) {
  if (!files.length) return;
  progress.innerHTML = '';
  progress.classList.add('show');
  const colors = { PNG:'#34d399', JPG:'#34d399', JPEG:'#34d399', PDF:'#f87171', MP4:'#fbbf24', DOCX:'#6c63ff' };
  Array.from(files).forEach((file, i) => {
    const ext = file.name.split('.').pop().toUpperCase();
    const col = colors[ext] || '#7b82a0';
    const item = document.createElement('div');
    item.className = 'progress-file';
    item.innerHTML = `
      <div class="progress-icon" style="background:${col}22">
        <svg viewBox="0 0 24 24" fill="none" stroke="${col}" stroke-width="2" width="14" height="14">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
        </svg>
      </div>
      <div class="progress-info">
        <div class="progress-name">${file.name}</div>
        <div class="progress-bar-wrap"><div class="progress-bar" id="bar${i}"></div></div>
      </div>
      <div class="progress-pct" id="pct${i}">0%</div>`;
    progress.appendChild(item);
  });
}

// ══════════════════════════════════════
// UPLOAD FILE TO BACKEND
// ══════════════════════════════════════
async function uploadFile(file, index) {
  const formData = new FormData();
  formData.append('file', file);
  let pct = 0;
  const bar   = document.getElementById('bar'  + index);
  const pctEl = document.getElementById('pct'  + index);
  const interval = setInterval(() => {
    pct = Math.min(pct + Math.random() * 12, 88);
    if (bar)   bar.style.width      = pct + '%';
    if (pctEl) pctEl.textContent    = Math.round(pct) + '%';
  }, 200);
  try {
    const res  = await fetch(`${BASE}/file/upload`, { method: 'POST', body: formData });
    const data = await res.json();
    clearInterval(interval);
    if (bar)   bar.style.width   = '100%';
    if (pctEl) pctEl.textContent = '100%';
    return res.ok ? data.file : null;
  } catch(e) {
    clearInterval(interval);
    console.error('Upload error:', e);
    return null;
  }
}

uploadBtn.addEventListener('click', async () => {
  const files = fileInput.files;
  if (!files.length) { fileInput.click(); return; }
  uploadBtn.textContent = 'Uploading...';
  uploadBtn.disabled = true;
  for (let i = 0; i < files.length; i++) {
    await uploadFile(files[i], i);
  }
  await loadFiles(); // ✅ refresh grid after upload
  uploadBtn.textContent = '✓ Done!';
  uploadBtn.style.background = '#34d399';
  setTimeout(() => closeModal(), 1200);
});

// ══════════════════════════════════════
// INIT
// ══════════════════════════════════════
loadFiles();
</script>
</body>
</html>
